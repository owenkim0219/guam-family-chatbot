# ===========================================
# 괌 가족여행 챗봇 — 환경변수 템플릿
# ===========================================
# 사용법:
#   1. 이 파일을 복사해서 .env 라는 이름으로 만든다
#   2. 각 키 옆 = 뒤에 본인의 실제 API 키를 입력한다
#   3. .env 는 절대 GitHub에 올리지 않는다 (.gitignore 처리됨)
# ===========================================

# --- Upstage Solar (LLM + Embedding) ---
# 발급: https://console.upstage.ai/api-keys
UPSTAGE_API_KEY=

# --- OpenWeatherMap (날씨 도구) ---
# 발급: https://home.openweathermap.org/api_keys
# ⚠️ One Call 3.0 절대 신청 X (카드 등록 요구함)
# 사용 엔드포인트: 5-day / 3-hour Forecast (무료)
OPENWEATHER_API_KEY=

# --- 한국은행 ECOS (환율 도구) ---
# 발급: https://ecos.bok.or.kr/api/
# 통계표 코드: 731Y001 (주요국 통화의 대원화환율)
ECOS_API_KEY=

# --- Tavily Web Search (선택 — 현재 미구현, README "향후 확장" 참조) ---
# 발급: https://app.tavily.com/
# 무료 1,000 크레딧/월, 미사용 크레딧 월말 소멸
# 본 프로젝트는 Level 2 범위로 미구현. Level 3 확장 시 src/guam_chatbot/tools/ 에 추가 예정.
TAVILY_API_KEY=